{
	"name": "ak-gemini",
	"author": "ak@mixpanel.com",
	"description": "AK's Generative AI Helper for doing... transforms",
	"version": "1.2.0",
	"main": "index.js",
	"files": [
		"index.js",
		"index.cjs",
		"agent.js",
		"tools.js",
		"types.d.ts",
		"logger.js"
	],
	"types": "types.d.ts",
	"exports": {
		".": {
			"import": {
				"types": "./types.d.ts",
				"default": "./index.js"
			},
			"require": {
				"types": "./types.d.ts",
				"default": "./index.cjs"
			}
		}
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ak--47/ak-gemini"
	},
	"bugs": {
		"url": "https://github.com/ak--47/ak-gemini/issues"
	},
	"homepage": "https://github.com/ak--47/ak-gemini#readme",
	"scripts": {
		"prepublishOnly": "npm run typecheck && npm run build:cjs",
		"post": "npm publish",
		"release": "npm version patch && npm publish --access public",
		"update-deps": "npx npm-check-updates -u && npm install",
		"prune": "rm -rf tmp/*",
		"test": "node --no-warnings --experimental-vm-modules node_modules/jest/bin/jest.js",
		"build:cjs": "esbuild index.js --bundle --platform=node --format=cjs --outfile=index.cjs --external:@google/genai --external:ak-tools --external:dotenv --external:pino-pretty --external:pino",
		"coverage": "node --no-warnings --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
		"typecheck": "tsc --noEmit",
		"update:gemini": "npm install @google/genai@latest"
	},
	"type": "module",
	"keywords": [
		"gemini",
		"ai wrapper",
		"json transform"
	],
	"license": "ISC",
	"dependencies": {
		"@google/genai": "^1.44.0",
		"ak-tools": "^1.1.12",
		"dotenv": "^17.3.1",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3"
	},
	"devDependencies": {
		"@types/jest": "^30.0.0",
		"esbuild": "^0.27.4",
		"jest": "^30.3.0",
		"nodemon": "^3.1.14",
		"typescript": "^5.9.3"
	}
}
